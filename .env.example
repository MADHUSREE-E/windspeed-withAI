# ──────────────────────────────────────────────────────────────────────────────
# WindCast Pro — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Email OTP via EmailJS (https://www.emailjs.com) ──────────────────────────
# 1. Sign up free at emailjs.com
# 2. Add an Email Service (Gmail, Outlook, etc.) → copy Service ID
# 3. Create a Template with variables:
#      {{to_name}}  — recipient name
#      {{to_email}} — recipient email
#      {{otp_code}} — the OTP code
#      {{expiry}}   — "10 minutes"
#    Copy Template ID
# 4. Account → General → Public Key
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ── SMS OTP via TextBelt (https://textbelt.com) ───────────────────────────────
# Free tier: use key "textbelt" for 1 free SMS/day (good for testing)
# Paid: buy credits at textbelt.com and use your API key for unlimited SMS
VITE_TEXTBELT_KEY=textbelt
